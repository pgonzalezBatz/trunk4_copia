    <add name="GESTIONHORASLIVE" connectionString="Data Source=XBAT;User Id=gestionhoras;Password=gestionhoras12;"/>
    <add name="DBIZAROTEST" connectionString="Data Source=GARAPEN;User Id=dbizaro;Password=dbizaro12;"/>
    <add name="DBIZAROLIVE" connectionString="Data Source=XBAT;User Id=dbizaro;Password=dbizaro12;"/>
