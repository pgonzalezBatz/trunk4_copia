<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net" />
  </configSections>
  <log4net debug="true" xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
    <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
      <file value="\\svm_cifs\AreaWeb\LOGS\PRO\INT\SolicitudesCR\Log.text" xdt:Transform="Replace" />
    </appender>
    <root>
      <appender-ref ref="SmtpAppender" xdt:Transform="Insert" xdt:Locator="Match(ref)" />
    </root>
    <logger>
      <appender-ref ref="SmtpAppender" xdt:Transform="Insert" xdt:Locator="Match(ref)" />
    </logger>
    <appender name="SmtpAppender" type="log4net.Appender.SmtpAppender">
      <to value="developers@batz.es" xdt:Transform="Replace" />
    </appender>
  </log4net>
</configuration>