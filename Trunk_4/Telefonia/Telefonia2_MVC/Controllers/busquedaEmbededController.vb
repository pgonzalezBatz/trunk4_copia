Imports System.Web.Mvc

Namespace Controllers
    Public Class busquedaEmbededController
        Inherits Controller

        Dim strCn = ConfigurationManager.ConnectionStrings("oracle").ConnectionString
        Dim strCnEpsilon = ConfigurationManager.ConnectionStrings("epsilon").ConnectionString

        ' GET: busqueda
        Function Index(id As Nullable(Of Integer), iddepartamento As String, idPlanta As Nullable(Of Integer)) As ActionResult
            Return View()
        End Function
        Function moreresults(q As String) As ActionResult
            Dim lst = db.GetListOfNombresSab(strCn).Where(Function(o)
                                                              Return h.searchFilter(q, o.nombre, o.apellido1, o.apellido2)
                                                          End Function)
            Dim lstExt = db.GetListOfExtensiones(strCn).Where(Function(e) e.extensionInterna.contains(q) Or e.extensionExterna.contains(q) Or e.numero.contains(q))
            Return View(Enumerable.Concat(lst, lstExt))
        End Function
        Function Planta() As ActionResult
            Return View(db.GetListOfPlanta(strCn))
        End Function
        Function Departamento(idPlanta As Integer, nombrePlanta As String) As ActionResult
            Return View(db.GetListOfDepartamentos(idPlanta, strCn, strCnEpsilon))
        End Function
        Function DepartamentoTelefonos(idPlanta As Integer, nombrePlanta As String, idDepartamento As String, nombreDepartamento As String) As ActionResult
            Return View(db.GetTelefonosDepartamento(idPlanta, idDepartamento, strCn))
        End Function
        Function GetNames(q As String) As JsonResult
            Dim lst = db.GetListOfNombresSab(strCn).Where(Function(o)
                                                              Return h.searchFilter(q, o.nombre, o.apellido1, o.apellido2)
                                                          End Function)
            Dim lstExt = db.GetListOfExtensiones(strCn).Where(Function(e) e.extensionInterna.contains(q) Or e.extensionExterna.contains(q) Or e.numero.contains(q))
            Return Json(Enumerable.Concat(lst, lstExt), JsonRequestBehavior.AllowGet)
        End Function
        Function getdeps(q As String) As JsonResult
            If String.IsNullOrEmpty(q) Then
                Return Json(New List(Of Object), JsonRequestBehavior.AllowGet)
            End If
            Dim lstDeps = db.GetListOfDepartamentos(strCn, strCnEpsilon).Where(Function(e) e.nombre.tolower.contains(q.ToLower))
            Return Json(lstDeps.ToList, JsonRequestBehavior.AllowGet)
        End Function
        Function GetOtros(q As String) As JsonResult
            If String.IsNullOrEmpty(q) Then
                Return Json(New List(Of Object), JsonRequestBehavior.AllowGet)
            End If
            Dim lstOtros = db.GetListOfOtros(strCn).Where(Function(o) o.nombre.tolower.contains(q.ToLower) OrElse o.extensionOtro.ToString().Contains(q) OrElse o.numero.ToString().Contains(q))
            Return Json(lstOtros.ToList, JsonRequestBehavior.AllowGet)
        End Function
        Function Detail(id As Integer) As PartialViewResult
            Dim p = db.GetDatosUsuario(id, strCn, strCnEpsilon)
            p.lstExtension = db.GetTelefonosUsuario(id, strCn).Select(Function(ex) New Extension With {.extensionInterna = ex.extensionInterna, .extensionExterna = ex.extensionExterna,
                                                    .numero = ex.numero, .tipoLinea = ex.tipoLinea, .internoDirecto = ex.internoDirecto})
            ViewData("planta") = db.GetDatosPlanta(p.idPlanta, strCn)
            Return PartialView("detail_partial", p)
        End Function
        Function DetailDepartamento(id As String, planta As Integer, nombreDepartamento As String) As PartialViewResult
            ViewData("nombreDepartamento") = nombreDepartamento
            ViewData("planta") = db.GetDatosPlanta(planta, strCn)
            Return PartialView("detail_partial_dep", db.GetTelefonosDepartamento(planta, id, strCn))
        End Function

        Function DetailOtros(nombre As String)
            Return PartialView("detail_partial_otr", db.GetListOfOtros(strCn, nombre))
        End Function
