<?xml version="1.0" encoding="utf-8"?>

<!-- Para obtener más información sobre el uso de la transformación de web.config, visite http://go.microsoft.com/fwlink/?LinkId=125889 -->

<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <appSettings>
    <add key="CurrentStatus" value="Live" xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
    <add key="LocalPath" value="\\svm_cifs.batz.es\AreaWeb\DATA\PRO\LanguageAdministration\language\" xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
  </appSettings>
	<connectionStrings>
    <!--	<add name="Entities_Gertakariak" connectionString="metadata=res://*/Oracle.Gertakariak.Gertakariak.csdl|res://*/Oracle.Gertakariak.Gertakariak.ssdl|res://*/Oracle.Gertakariak.Gertakariak.msl;provider=Oracle.ManagedDataAccess.Client;provider connection string=&quot;data source=xbat;password=incidencias12;user id=incidencias;validate connection=True&quot;" providerName="System.Data.EntityClient" />-->
    <add xdt:Transform="SetAttributes" xdt:Locator="Match(name)" name="Entities_Gertakariak" connectionString="metadata=res://*/Oracle.Gertakariak.Gertakariak.csdl|res://*/Oracle.Gertakariak.Gertakariak.ssdl|res://*/Oracle.Gertakariak.Gertakariak.msl;provider=Oracle.ManagedDataAccess.Client;provider connection string=&quot;data source=xbat;password=incidencias12;user id=incidencias;validate connection=True&quot;"/>
    <add xdt:Transform="SetAttributes" xdt:Locator="Match(name)" name="SABLIVE" connectionString="Data Source=XBAT;User Id=sab;Password=sab12;Connection LifeTime=300;statement cache purge=True;validate connection=True;ha events=False;"/>
    <add xdt:Transform="RemoveAll" xdt:Locator="Condition(contains(@name, 'TEST'))" connectionString="" name="" />
	</connectionStrings>  
	<system.web>
		<compilation xdt:Transform="RemoveAttributes(debug, assemblyPostProcessorType)"/>
	</system.web>
  <system.webServer>
    <security xdt:Transform="Insert">
      <authentication>
        <windowsAuthentication  enabled="true"  />
        <anonymousAuthentication enabled="false" />
      </authentication>
    </security>
  </system.webServer>
   <applicationSettings>
    <IstrikuWebRaiz.My.MySettings>
      <setting xdt:Locator="Match(name)" name="IdListadoNotificaciones">
        <value xdt:Transform="Replace">885</value>
      </setting>
    </IstrikuWebRaiz.My.MySettings>
  </applicationSettings>
  <log4net>
    <appender>
      <file xdt:Transform="SetAttributes" value="\\svm_cifs.batz.es\AreaWeb\LOGS\PRO\INT\Istriku\Log"/>
    </appender>
    <root>
      <appender-ref xdt:Transform="Remove" xdt:Locator="Match(ref)"  ref="SmtpAppender"/>
      <appender-ref xdt:Transform="Insert" ref="SmtpAppender"/>
    </root>
  </log4net>
</configuration>