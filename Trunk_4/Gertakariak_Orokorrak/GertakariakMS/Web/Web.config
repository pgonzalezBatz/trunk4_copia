		</handlers>
	</system.webServer>
	<appSettings>
    <!-- Sistema de traduccion ==================================================================-->
    <add key="AccederEnLocal" value="true" />
    <add key="LocalPath" value="\\svm_cifs.batz.es\AreaWeb\DATA\PRO\LanguageAdministration\languageApp\" />
    <!--=========================================================================================-->
		<add key="RemotePath" value="http://petrondegi.batz.es/WSTraducciones/" />
		<add key="RecursoWeb" value="265" />
		<add key="CurrentStatus" value="Live" />
		<add key="ChartImageHandler" value="storage=file;timeout=20;dir=c:\TempImageFiles\;" />
	
	<!--<add key="Microsoft.VisualStudio.Enterprise.AspNetHelper.VsInstrLocation" value="C:\Program Files (x86)\Microsoft Visual Studio\2017\Enterprise\Team Tools\Performance Tools\vsinstr.exe" />-->
	
	
	
	
	</appSettings>
	<connectionStrings>
		<add name="SABTEST" connectionString="Data Source=GARAPEN;User Id=sab;Password=sab12;Connection LifeTime=300;" />
		<add name="SABLIVE" connectionString="Data Source=XBAT;User Id=sab;Password=sab12;Connection LifeTime=300;" />
		<add name="PrismaTest" connectionString="DATA SOURCE=GARAPEN;PASSWORD=prisma312;PERSIST SECURITY INFO=True;USER ID=prisma3" />
		<add name="PrismaLive" connectionString="DATA SOURCE=COGNOS10;PASSWORD=prisma312;PERSIST SECURITY INFO=True;USER ID=prisma3" />
		<add name="ConexionWeb_TEST" connectionString="Data Source=GARAPEN;User Id=incidencias;Password=incidencias12;Connection LifeTime=300;" />
		<add name="ConexionWeb_LIVE" connectionString="Data Source=XBAT;User Id=incidencias;Password=incidencias12;Connection LifeTime=300;" />	
		<add name="Entities_Gertakariak" connectionString="metadata=res://*/Oracle.Gertakariak.Gertakariak.csdl|res://*/Oracle.Gertakariak.Gertakariak.ssdl|res://*/Oracle.Gertakariak.Gertakariak.msl;provider=Oracle.ManagedDataAccess.Client;provider connection string=&quot;data source=XBAT;ha events=False;load balancing=False;password=incidencias12;statement cache purge=True;user id=incidencias;validate connection=True&quot;" providerName="System.Data.EntityClient" />
	</connectionStrings>
	<system.web>
		<httpHandlers>
			<add path="ChartImg.axd" verb="GET,HEAD,POST" type="System.Web.UI.DataVisualization.Charting.ChartHttpHandler, System.Web.DataVisualization, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35" validate="false" />
		</httpHandlers>
		<siteMap defaultProvider="WebSiteMap">
			<providers>
				<add name="WebSiteMap" type="System.Web.XmlSiteMapProvider" siteMapFile="~/App_Data/Web.sitemap" />
			</providers>
		</siteMap>
		<!--============================================================================================================================-->
		<pages theme="Batz">
			<controls>
				<add tagPrefix="act" namespace="AjaxControlToolkit" assembly="AjaxControlToolkit" />
				<add tagPrefix="uc" tagName="SiteMapPath" src="~/Controles/MapaSitio.ascx" />
				<add tagPrefix="PanelCargandoDatos" tagName="PanelCargandoDatos" src="~/Controles/PanelCargandoDatos.ascx" />
				<add tagPrefix="ascx" tagName="Titulo" src="~/Controles/Titulo.ascx" />
				<add tagPrefix="ascx" tagName="Mensajes" src="~/Controles/Mensajes.ascx" />
      <add tagPrefix="ajaxToolkit" assembly="AjaxControlToolkit" namespace="AjaxControlToolkit" /></controls>
		</pages>
		<!--============================================================================================================================-->
		<!--============================================================================================================================-->
		<!-- FROGA: 2013-07-10 -->
		<!--============================================================================================================================-->
		<!--<pages styleSheetTheme="BatzIE8">		
		<controls>
				<add tagPrefix="act" namespace="AjaxControlToolkit" assembly="AjaxControlToolkit" />
				<add tagPrefix="uc" tagName="SiteMapPath" src="~/Controles/MapaSitio.ascx" />
			</controls>
		</pages>-->
		<!--============================================================================================================================-->
		
		<!--
          Set compilation debug="true" to insert debugging
          symbols into the compiled page. Because this
          affects performance, set this value to true only
          during development.
    -->
		<roleManager enabled="true" />
		<!-- pageOutput="false" para evitar errores de JScript. Para consulta el seguimiento ir a "http://localhost:10699/Trace.axd". -->
		<trace enabled="true" pageOutput="false" requestLimit="50" mostRecent="true" localOnly="true" traceMode="SortByTime" />
		<customErrors mode="Off" />
		<!--<compilation debug="false" > Genera menos codigo a la hora de compilar. -->
		<compilation debug="true" targetFramework="4.0" assemblyPostProcessorType="Microsoft.VisualStudio.Enterprise.Common.AspPerformanceInstrumenter, Microsoft.VisualStudio.Enterprise.AspNetHelper, Version=15.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a">
			<assemblies>
				<add assembly="System.Design, Version=4.0.0.0, Culture=neutral, PublicKeyToken=B03F5F7F11D50A3A" />
				<add assembly="System.Web.Extensions.Design, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35" />
				<add assembly="System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=B77A5C561934E089" />
				<add assembly="System.Web.DataVisualization, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35" />
			</assemblies>
		</compilation>
	</system.web>

	<runtime>
		<assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
			<dependentAssembly>
				<assemblyIdentity name="Microsoft.VisualStudio.Enterprise.AspNetHelper" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
				<codeBase version="12.0.0.0" href="file:///C:/Program%20Files%20(x86)/Microsoft%20Visual%20Studio%2012.0/Common7/IDE/PrivateAssemblies/Microsoft.VisualStudio.Enterprise.AspNetHelper.DLL" />
				<codeBase version="15.0.0.0" href="file:///C:/Program%20Files%20(x86)/Microsoft%20Visual%20Studio/Shared/Common/VSPerfCollectionTools/Microsoft.VisualStudio.Enterprise.AspNetHelper.DLL" /></dependentAssembly>
			<dependentAssembly>
				<assemblyIdentity name="DocumentFormat.OpenXml" publicKeyToken="31bf3856ad364e35" culture="neutral" />
				<bindingRedirect oldVersion="0.0.0.0-2.5.5631.0" newVersion="2.5.5631.0" />
			</dependentAssembly>
			<dependentAssembly>
				<assemblyIdentity name="HtmlAgilityPack" publicKeyToken="bd319b19eaf3b43a" culture="neutral" />
				<bindingRedirect oldVersion="0.0.0.0-1.4.9.0" newVersion="1.4.9.0" />
			</dependentAssembly>
			<dependentAssembly>
				<assemblyIdentity name="AjaxMin" publicKeyToken="21ef50ce11b5d80f" culture="neutral" />
				<bindingRedirect oldVersion="0.0.0.0-5.14.5506.26196" newVersion="5.14.5506.26196" />
			</dependentAssembly>		
			<dependentAssembly>
				<assemblyIdentity name="VsWebSite.Interop" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
				<codeBase version="8.0.0.0" href="file:///C:/Program%20Files%20(x86)/Microsoft%20Visual%20Studio/Shared/Common/VSPerfCollectionTools/VsWebSite.Interop.DLL" /></dependentAssembly>
			<dependentAssembly>
				<publisherPolicy apply="no" />
				<assemblyIdentity name="Oracle.ManagedDataAccess" publicKeyToken="89b483f429c47342" culture="neutral" />
			</dependentAssembly>
		</assemblyBinding></runtime>
  <log4net debug="true" xsi:noNamespaceSchemaLocation="http://csharptest.net/downloads/schema/log4net.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
 <!--RollingFileAppender escribe todos los tipos de error-->
    <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
      <!-- ** Ruta y Nombre del Archivo **************************************************** -->
      <file value=".\Logs\Log" />
      <!--Extension del Archivo-->
      <datePattern value="'.'yyyy-MM-dd'.log'" />
      <!-- ********************************************************************************* -->
      <appendToFile value="true" />
      <staticLogFileName value="false" />
      <maximumFileSize value="1MB" />
      <maxSizeRollBackups value="2" />
      <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
      <layout type="log4net.Layout.PatternLayout">
        <!--<conversionPattern value="%date{HH:mm} %level %property{log4net:HostName} %username %logger %class - %message %newline"/>-->
        <!-- Patron estardar para escribir el mensaje en los Logs -->
        <conversionPattern value="%date{HH:mm:ss} %level %property{log4net:HostName} %identity %class -%message%newline" />
      </layout>
      <!--<filter type="log4net.Filter.LevelRangeFilter">
        <param name="LevelMin" value="WARN"/>
        <param name="LevelMax" value="FATAL"/>
      </filter>-->
    </appender>

    <!--SmtpAppender solo envia correos de error del tipo "ERROR" y "FATAL"-->
    <appender name="SmtpAppender" type="log4net.Appender.SmtpAppender,log4net">
      <to value="diglesias@batz.es" />
      <from value="log4net@batz.es" />
      <subject value="Error en .NET" />
      <smtpHost value="POSTA.BATZ.ES" />
      <bufferSize value="512" />
      <lossy value="false" />
      <evaluator type="log4net.Core.LevelEvaluator,log4net">
        <threshold value="WARN" />
      </evaluator>
      <filter type="log4net.Filter.LevelRangeFilter">
        <param name="LevelMin" value="ERROR" />
        <param name="LevelMax" value="FATAL" />
      </filter>
      <layout type="log4net.Layout.PatternLayout,log4net">
        <conversionPattern value="Fecha: %date %newline Nivel: %level %newline Logger: %logger %newline Maquina: %property{log4net:HostName} %newline Usuario: %username (%identity)  %newline Clase: %class %newline  Message: %message%newline" />
      </layout>
    </appender>

    <!--AspNetTraceAppender escrice mensajes en el TraceContext si el seguimiento esta activado-->
    <appender name="AspNetTraceAppender" type="log4net.Appender.AspNetTraceAppender,log4net">
      <layout type="log4net.Layout.PatternLayout,log4net">
        <conversionPattern value="%date [%thread] %-5level %logger [%property{NDC}] - %message%newline" />
      </layout>
    </appender>
  
    <root>
      <appender-ref ref="RollingFileAppender" />
      <appender-ref ref="AspNetTraceAppender" />
    </root>

  </log4net>
  <system.data>
    <DbProviderFactories>
      <remove invariant="Oracle.ManagedDataAccess.Client" />
      <add name="ODP.NET, Managed Driver" invariant="Oracle.ManagedDataAccess.Client" description="Oracle Data Provider for .NET, Managed Driver" type="Oracle.ManagedDataAccess.Client.OracleClientFactory, Oracle.ManagedDataAccess, Version=4.122.18.3, Culture=neutral, PublicKeyToken=89b483f429c47342" />
    </DbProviderFactories>
  </system.data>
  <!--<oracle.manageddataaccess.client>
    <version number="*">
      <dataSources>
        <dataSource alias="SampleDataSource" descriptor="(DESCRIPTION=(ADDRESS=(PROTOCOL=tcp)(HOST=localhost)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=ORCL))) " />
      </dataSources>
    </version>
  </oracle.manageddataaccess.client>-->
</configuration>