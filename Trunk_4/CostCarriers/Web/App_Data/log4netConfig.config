<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section  name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
  </configSections>

  <log4net debug="true">

    <!--RollingFileAppender escribe todos los tipos de error-->
    <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
      <file value="\\svm_cifs.batz.es\AreaWeb\LOGS\PRO\INT\CostCarriers\Log"/>
      <datePattern value="'-'yyyy-MM-dd'.log'" />
      <appendToFile value="true"/>
      <staticLogFileName value="false" />
      <maximumFileSize value="100KB"/>
      <maxSizeRollBackups value="2"/>
      <lockingModel type="log4net.Appender.FileAppender+MinimalLock"/>
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date{HH:mm:ss} %level %property{log4net:HostName} %identity %class - %message%newline"/>
      </layout>
    </appender>

    <!--SmtpAppender solo envia correos de error del tipo "ERROR" y "FATAL"-->
    <appender name="SmtpAppender" type="log4net.Appender.SmtpAppender">
      <to value="abelgarcia@batz.es" />
      <from value="costcarriers@batz.es" />
      <subject value="ERROR en la aplicación de Cost carriers" />
      <smtpHost value="posta.batz.es" />
      <bufferSize value="512" />
      <lossy value="true" />
      <evaluator type="log4net.Core.LevelEvaluator">
        <threshold value="WARN" />
      </evaluator>
      <filter type="log4net.Filter.LevelRangeFilter">
        <param name="LevelMin" value="ERROR"/>
        <param name="LevelMax" value="FATAL"/>
      </filter>
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date{HH:mm:ss} %level %property{log4net:HostName} %identity %class - %message%newline"/>
      </layout>
    </appender>

    <logger name="root">
      <level value="DEBUG" />
      <appender-ref ref="RollingFileAppender"/>
      <appender-ref ref="SmtpAppender"/>
    </logger>

  </log4net>
</configuration>
