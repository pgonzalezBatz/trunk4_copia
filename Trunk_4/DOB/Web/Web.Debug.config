<?xml version="1.0" encoding="utf-8"?>

<!-- Para obtener más información sobre el uso de la transformación de web.config, visite http://go.microsoft.com/fwlink/?LinkId=125889 -->

<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <appSettings>
    <add key="CurrentStatus" value="debug" xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
    <add key="RecursoWeb" value="395" xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
    <add key="rootDocumentos" value="\\svm_cifs.batz.es\AreaWeb\DATA\TEST\DOB\DOCUMENTOS" xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
    <add key="IdGrupoConsejoRector" value="379" xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
    <add key="IdGrupoSeguimiento" value="333" xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
  </appSettings>
  <connectionStrings>
    <add xdt:Transform="RemoveAll" xdt:Locator="Condition(contains(@name, 'LIVE'))" connectionString="" name="" />
  </connectionStrings>

  <system.webServer xdt:Transform="Insert">
    <security>
      <authentication>
        <windowsAuthentication enabled="true"  />
        <anonymousAuthentication enabled="false" />
      </authentication>
    </security>
  </system.webServer>

</configuration>