<%@ Control Language="vb" AutoEventWireup="false" CodeBehind="FinalizarProc.ascx.vb" Inherits="WebRaiz.FinalizarProc" %>
<%@ Register Assembly="AjaxControlToolkit" Namespace="AjaxControlToolkit" TagPrefix="ajax" %>
 <script type="text/javascript" src="../../js/Utiles.js"></script>
<!--Script references. -->
<script src="../../js/jquery/jquery-1.6.4.min.js"></script>
<script src="../../js/jQuery/jquery.toastmessage.js"></script>
<script src="../../Scripts/jquery.signalR-2.3.0.js"></script>
<!--Reference the autogenerated SignalR hub script. -->
<script src="../../signalr/hubs"></script>
<!--Add script to update the page and send messages.-->
<script type="text/javascript">
    $(function () {        
        var myhub = $.connection.signalRHub;                
        myhub.client.showMessage = function (step,message) {
            // Html encode display step and message.    
            var step= $('<div />').text(step).html();
            var message = $('<div />').text(message).html();            
            $('#spanStep').text(step);
            $('#spanMessage').text(message);
        };                    
        // Start the connection.
        //$.connection.hub.logging = true;
        $.connection.hub.start().done(function () {
            $('#' + '<%=btnFinalizar.ClientID%>').click(function () {
                $('#' + '<%=pnlDatosNecesarios.ClientID%>').hide();
                $('#' + '<%=pnlExecuting.ClientID%>').show();    
                $('#' + '<%=hfConnectionId.ClientID%>').val(myhub.connection.id);    
                // Call the Send method on the hub.
                //myhub.server.send("Mensaje javascript");                
            });           
        });       
    });
</script>
<fieldset style="width:1000px">    
    <br /><asp:Label runat="server" ID="labelInfo1" Text="Al finalizar el proceso, se realizara lo siguiente" CssClass="labelDetalle"></asp:Label><br /><%--Al finalizar el proceso, se realizaran 2 tareas--%>
    <ul>
        <li><asp:Label runat="server" ID="labelInfo2" Text="Se guardaran las facturas y albaranes subidas" CssClass="labelDetalle"></asp:Label></li>
        <li><asp:Label runat="server" ID="labelInfo3" Text="Se realizaran los asientos contables en NAVISION" CssClass="labelDetalle"></asp:Label></li>
