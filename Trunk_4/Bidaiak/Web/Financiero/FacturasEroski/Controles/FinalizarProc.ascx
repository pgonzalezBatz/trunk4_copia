                <td>
                    <asp:TextBox ID="txtFechaVen" runat="server" contentEditable="false" Columns="10"></asp:TextBox>
		            <asp:ImageButton ID="imgCalendarioFV" runat="server" ImageUrl="~/App_Themes/Tema1/IconosAjaxControl/CalendarExtender/Calendario.gif" />
		            <ajax:CalendarExtender ID="ceFV" runat="server" TargetControlID="txtFechaVen" PopupButtonID="imgCalendarioFV" />           	
                </td>
                <td style="padding-left:25px;"><asp:Label runat="server" ID="labelFFactura" Text="Fecha factura" CssClass="labelDetalle"></asp:Label></td>
                <td>
                    <asp:TextBox ID="txtFechaFact" runat="server" contentEditable="false" Columns="10"></asp:TextBox>
		            <asp:ImageButton ID="imgCalendarioFF" runat="server" ImageUrl="~/App_Themes/Tema1/IconosAjaxControl/CalendarExtender/Calendario.gif" />
		            <ajax:CalendarExtender ID="ceFF" runat="server" TargetControlID="txtFechaFact" PopupButtonID="imgCalendarioFF" />           	
                </td>
            </tr>
            <tr>
                <td colspan="4"><hr /></td>
            </tr>
            <tr>
                <td><asp:Label runat="server" ID="labelImporte" Text="Importe" CssClass="labelDetalle"></asp:Label></td>
                <td><asp:Label runat="server" ID="lblImporte" CssClass="negrita"></asp:Label></td>
                <td style="padding-left:25px;"><asp:Label runat="server" ID="labelIVA" Text="IVA" CssClass="labelDetalle"></asp:Label></td>
                <td><asp:Label runat="server" ID="lblIVA" CssClass="negrita"></asp:Label></td>
            </tr> 
            <tr>
                <td><asp:Label runat="server" ID="labelImporteTotal" Text="Importe total" CssClass="labelDetalle"></asp:Label></td>
                <td><asp:Label runat="server" ID="lblImporteTotal" CssClass="negrita"></asp:Label></td>
            </tr>             
            <asp:Panel runat="server" ID="pnlAsientosNoIntegrar">
                <tr>
                    <td colspan="2"><br /><asp:Label runat="server" ID="lblNoIntegrar" CssClass="labelDetalle"></asp:Label></td>
                </tr>
            </asp:Panel>           
        </table><br />
         <asp:Panel runat="server" ID="pnlDocImportes" GroupingText="Facturas">                                    
            <table cellpadding="1" cellspacing="0">
                <asp:Repeater runat="server" ID="rptFacturas">
                    <ItemTemplate>
				        <tr>
                            <td><asp:Label runat="server" ID="labelNFacturaF" Text="N. factura" CssClass="labelDetalle"></asp:Label>:</td>
                            <td>
                                <asp:Label runat="server" ID="lblNFacturaF" CssClass="negrita"></asp:Label>
                                <asp:HiddenField runat="server" ID="hfNFacturaF" />
                            </td>
                            <td style="padding-left:25px;"><asp:Label runat="server" ID="labelDocBatzF" Text="Doc Batz" CssClass="labelDetalle"></asp:Label></td>
                            <td>
                                <asp:TextBox runat="server" ID="txtDocBatzF" MaxLength="15" CssClass="campoObligatorio"></asp:TextBox>
                                <asp:RequiredFieldValidator ID="rfvDocBatzF" runat="server" Display="None" ControlToValidate="txtDocBatzF" ValidationGroup="Save" ErrorMessage="Introduzca el dato"></asp:RequiredFieldValidator>
	                            <ajax:ValidatorCalloutExtender runat="server" ID="vceDocBatzF" TargetControlID="rfvDocBatzF" />
                            </td>
                            <td style="padding-left:25px;"><asp:Label runat="server" ID="labelImporteF" Text="Importe" CssClass="labelDetalle"></asp:Label></td>
                            <td><asp:Label runat="server" ID="lblImporteF" CssClass="negrita"></asp:Label></td>
                            <td style="padding-left:25px;"><asp:Label runat="server" ID="labelIVAF" Text="IVA" CssClass="labelDetalle"></asp:Label></td>
                            <td><asp:Label runat="server" ID="lblIVAF" CssClass="negrita"></asp:Label></td>
                            <td style="padding-left:25px;"><asp:Label runat="server" ID="labelImporteTotalF" Text="Total" CssClass="labelDetalle"></asp:Label></td>
                            <td><asp:Label runat="server" ID="lblImporteTotalF" CssClass="negrita"></asp:Label></td>
                        </tr>	
