<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <appSettings>
    <add xdt:Transform="SetAttributes" xdt:Locator="Match(key)" key="CurrentStatus" value="Debug"/>
    <add xdt:Transform="SetAttributes" xdt:Locator="Match(key)" key="Documentos" value="\\svm_cifs.batz.es\AreaWeb\DATA\TEST\Bidaiak"/>
    <add xdt:Transform="SetAttributes" xdt:Locator="Match(key)" key="pathBidaiak" value="\\svm_cifs.batz.es\AreaWeb\APPS\TEST\INT\Bidaiak\Web"/>    
  </appSettings>
  <connectionStrings>
    <add xdt:Transform="RemoveAll" xdt:Locator="Condition(contains(@name,'LIVE'))" connectionString="" name="" />
  </connectionStrings>
  <system.webServer xdt:Transform="Insert">
    <security>
      <authentication>
        <windowsAuthentication  enabled="true"  />
        <anonymousAuthentication enabled="false" />
      </authentication>
    </security>
  </system.webServer>
</configuration>