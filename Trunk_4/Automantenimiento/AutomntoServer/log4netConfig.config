<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<configSections>
		<section  name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
	</configSections>
	<log4net debug="true">
		<appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
      <!-- ** Ruta y Nombre del Archivo **************************************************** -->
      <file type="log4net.Util.PatternString" value="\\%property{ServerName}\Automnto\Logs\%property{LogName}.log" />            
			<appendToFile value="true"/>      
			<staticLogFileName value="true" /> <!--Para que no añada la fecha al nombre-->
			<maximumFileSize value="1MB"/>
			<maxSizeRollBackups value="2"/>
			<lockingModel type="log4net.Appender.FileAppender+MinimalLock"/>
			<layout type="log4net.Layout.PatternLayout">
				<conversionPattern value="%date{HH:mm:ss} %level %property{log4net:HostName} %logger %class - %message %newline"/>
			</layout>			
		</appender>
		<!--SmtpAppender solo envia correos de error del tipo "ERROR" y "FATAL"-->
		<appender name="SmtpAppender" type="log4net.Appender.SmtpAppender,log4net">
			<to value="abelgarcia@batz.es" />
			<from value="log4net@batz.es" />
			<subject value="Automantenimiento Server" />
			<smtpHost value="posta.batz.es" />
			<bufferSize value="512" />
			<lossy value="false" />
			<evaluator type="log4net.Core.LevelEvaluator,log4net">
				<threshold value="WARN" />
			</evaluator>
			<filter type="log4net.Filter.LevelRangeFilter">
				<param name="LevelMin" value="ERROR"/>
				<param name="LevelMax" value="FATAL"/>
			</filter>
			<layout type="log4net.Layout.PatternLayout,log4net">				
        <conversionPattern value="%newline Usuario: %username %newline Maquina: %property{log4net:HostName} %newline Nivel: %level %newline Logger: %logger %newline Date: %date %newline Clase: %class  %newline Message: %message" />
			</layout>
		</appender>
    <logger name="SERVER">
      <level value="DEBUG" />
      <appender-ref ref="RollingFileAppender"/>
    </logger>
	</log4net>
</configuration>