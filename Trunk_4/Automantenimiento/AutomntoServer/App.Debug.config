<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <appSettings>
    <add xdt:Transform="SetAttributes" xdt:Locator="Match(key)" key="CurrentStatus" value="Debug"/>
    <add xdt:Transform="SetAttributes" xdt:Locator="Match(key)" key="log4netPath" value="C:\Trunk_4\SBatz\Automantenimiento\AutomntoServer\log4netConfig.config"/>
    <add xdt:Transform="SetAttributes" xdt:Locator="Match(key)" key="IdPlanta" value="1"/>    
  </appSettings>
  <connectionStrings>
    <add xdt:Transform="RemoveAll" xdt:Locator="Condition(contains(@name,'LIVE'))" connectionString="" name="" />
  </connectionStrings>
</configuration>
